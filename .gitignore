# Dependencies (reinstall with: npm install)
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output (regenerated by: npm run dev / npm run build)
/.next/
/out/

# Production / generic build folders
/build
/dist

# Testing
/coverage

# Environment variables (secrets — never commit)
.env
.env.*
!.env.example

# Vercel deployment
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ESLint cache
.eslintcache

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# OneDrive / sync temp files
~$*
*.tmp
*.temp

# IDE / editor
.idea/
*.swp
*.swo
*~
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Optional: uncomment if you use Cursor locally and do not want it in the repo
# .cursor/

# Certificates / keys
*.pem
*.key

# Turbo (if used later)
.turbo
